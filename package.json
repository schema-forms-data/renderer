{
  "name": "@schema-forms-data/renderer",
  "version": "4.0.13",
  "description": "Form renderer for SchemaForms — renders FormSchema with react-hook-form",
  "license": "MIT",
  "author": "SchemaForms",
  "homepage": "https://schema-forms-data.github.io/schema-forms-data",
  "repository": {
    "type": "git",
    "url": "https://github.com/schema-forms-data/renderer.git"
  },
  "bugs": {
    "url": "https://github.com/schema-forms-data/renderer/issues"
  },
  "keywords": [
    "react",
    "forms",
    "schema",
    "renderer",
    "react-hook-form",
    "form-validation",
    "schema-forms-data"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@schema-forms-data/core": "4.0.12",
    "@schema-forms-data/templates": "4.0.13",
    "@schema-forms-data/ui": "4.0.12",
    "file-type": "22.0.1",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "lucide-react": "0.400.0",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "react-hook-form": "7.54.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "tailwindcss": "4.3.1",
    "typescript": "5.5.3",
    "vite": "5.4.2",
    "vite-plugin-dts": "4.0.0",
    "vitest": "2.1.0",
    "@vitest/coverage-v8": "2.1.0"
  },
  "packageManager": "pnpm@9.0.0"
}
